rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Empresas: solo el propio admin puede leer/escribir su empresa
    match /empresas/{empresaId} {
      allow read, write: if request.auth != null && request.auth.uid == empresaId;
    }

    // Empleados: el propio empleado puede leer/escribir su doc.
    // El admin de la empresa puede leer todos sus empleados.
    match /empleados/{empleadoId} {
      allow read, write: if request.auth != null && request.auth.uid == empleadoId;
      allow read: if request.auth != null && request.auth.uid == resource.data.empresaId;
    }

    // Fichajes: el empleado puede crear los suyos. El admin puede leer los de su empresa.
    match /fichajes/{fichajeId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.empleadoId;
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.empleadoId || request.auth.uid == resource.data.empresaId);
    }

    // Turnos: el admin escribe, los empleados leen
    match /turnos/{turnoId} {
      allow write: if request.auth != null;
      allow read:  if request.auth != null;
    }

    // Recordatorios enviados: el admin y el cron pueden leer/escribir
    match /recordatoriosEnviados/{docId} {
      allow read, write: if request.auth != null;
    }

    // Invitaciones: cualquier autenticado puede leer (para unirse)
    match /invitaciones/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
